# Environment variables for GraphChainSQLPython
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# ─── Deployment tier (dev | test | stg | prod) — aliases: ENVIRONMENT, NODE_ENV ───
APP_ENV=dev

# Logical service name for /health and OTEL resource (set in every real env)
SERVICE_NAME=graphchainsql-api

# Optional build id (shown in /health and OpenAPI)
APP_VERSION=0.0.0-local

# HTTP server bind (uvicorn)
API_HOST=0.0.0.0
API_PORT=8085

# After each completed non-cache query, run RAGAS in a background thread and store scores in Postgres (extra LLM cost)
RAGAS_COLLECT_ON_COMPLETE=false

# OTLP trace exporter (LangSmith-compatible HTTP OTLP base URL, no /v1/traces suffix)
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.smith.langchain.com/otel

# Database
DATABASE_URL=postgresql+asyncpg://warehouse_admin:warehouse_secret_2024@localhost:5433/warehouse_db
DATABASE_URL_SYNC=postgresql://warehouse_admin:warehouse_secret_2024@localhost:5433/warehouse_db

# Redis
REDIS_URL=redis://localhost:6379

# LangSmith Tracing
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_PROJECT=GraphChainSQL
LANGCHAIN_TRACING_V2=true

# Guardrails
GUARDRAILS_ENABLED=true

# RAGAS thresholds (for offline / quality-gate scripts)
RAGAS_SQL_CORRECTNESS_THRESHOLD=0.5
RAGAS_CONTEXT_PRECISION_THRESHOLD=0.4
RAGAS_QUALITY_GATE_THRESHOLD=0.55
